<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
    <metadata>
        <id>vaulkeeper</id>
        <version>0.1.0</version>
        <packageSourceUrl>https://github.com/vaulkeeper/chocolatey</packageSourceUrl>
        <owners>Vaulkeeper</owners>
        <title>Vaulkeeper</title>
        <authors>Vaulkeeper</authors>
        <projectUrl>https://vaulkeeper.local</projectUrl>
        <iconUrl>https://vaulkeeper.local/assets/logo.png</iconUrl>
        <copyright>Matteo</copyright>
        <licenseUrl>https://vaulkeeper.local/license</licenseUrl>
        <requireLicenseAcceptance>true</requireLicenseAcceptance>
        <projectSourceUrl>https://github.com/vaulkeeper/vaulkeeper</projectSourceUrl>
        <docsUrl>https://vaulkeeper.local/docs</docsUrl>
        <bugTrackerUrl>https://github.com/vaulkeeper/vaulkeeper/issues</bugTrackerUrl>
        <tags>storage windows cleanup ntfs smart duplicates uninstaller admin</tags>
        <summary>Native Windows storage manager</summary>
        <description>Vaulkeeper inspects disk usage, finds duplicates, uninstalls apps cleanly, reads SMART health, and automates maintenance safely. Scans via direct MFT reads for speed.</description>
        <releaseNotes>First public release.</releaseNotes>
    </metadata>
    <files>
        <file src="tools/**" target="tools" />
    </files>
</package>
