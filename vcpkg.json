{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg/master/scripts/vcpkg.schema.json",
  "name": "vaulkeeper",
  "version-string": "0.1.0",
  "description": "Native Windows storage manager built for speed and clarity",
  "homepage": "https://github.com/vaulkeeper/vaulkeeper",
  "supports": "windows & x64",
  "dependencies": [
    {
      "name": "qtbase",
      "version>=": "6.7.0",
      "default-features": false,
      "features": [
        "concurrent",
        "gui",
        "network",
        "widgets"
      ]
    },
    {
      "name": "qtdeclarative",
      "version>=": "6.7.0"
    },
    {
      "name": "qtsvg",
      "version>=": "6.7.0"
    },
    {
      "name": "qttools",
      "version>=": "6.7.0"
    },
    {
      "name": "sqlite3",
      "features": ["fts5"]
    },
    "xxhash",
    "blake3",
    "openssl",
    "libarchive",
    "zstd",
    "mimalloc",
    "tbb",
    "abseil",
    "spdlog",
    "tomlplusplus",
    "yaml-cpp",
    "fmt",
    "catch2",
    "benchmark",
    "lua"
  ],
  "builtin-baseline": "5e6578b62d9e4ac5a563e816802a56818540cd2e"
}
